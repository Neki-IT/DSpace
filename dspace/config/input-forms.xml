    <form name="produtosCulturais">
      <page number="1">
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>title</dc-element>
          <dc-qualifier />
          <parent />
          <label>Nome do Produto</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required>Você precisa nomear o produto!</required>
          <hint>Insira o nome do produto neste campo.</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>typology</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Tipologia</label>
          <input-type value-pairs-name="typology-list">dropdown</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Escolha um item.</hint>
        </field>
      	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>description</dc-element>
          <dc-qualifier>cultural</dc-qualifier>
          <parent />
