<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE input-forms>

<input-forms>
  <form-map>
    <name-map collection-handle="default" form-name="historias" />
    <name-map collection-handle="123456789/14" form-name="midia" />
    <name-map collection-handle="123456789/17" form-name="produtosCulturais" />
  </form-map>
  <form-definitions>
    <form name="historias">
      <page number="1">
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>title</dc-element>
          <dc-qualifier />
          <parent />
          <label>Nome da História</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required>Você precisa nomear sua história!</required>
          <hint>Insira o nome de sua história neste campo.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>author</dc-qualifier>
          <parent />
          <label>Pessoa</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required>Você precisa registrar pelo menos uma pessoa participante de sua história!</required>
          <hint>Quais são as pessoas presentes nesta história? Conte para nós! 
            Basta clicar na lupa ao lado e pesquisar pela(s) pessoa(s) participante(s).
            *A pessoa deve estar previamente cadastrada no menu de "Registro de Pessoas".</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>creator</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Autor</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Digite o nome do autor neste campo. *Lembrando que o autor deve ter um perfil de pessoa cadastrado na plataforma. *Este campo não é obrigatório.</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>organization</dc-element>
          <dc-qualifier>author</dc-qualifier>
          <parent />
          <label>Autoria Organizacional</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required>É necessário uma autoria!</required>
          <hint>A autoria orgnizacional padrão é do Museu da Pessoa. Caso a autoria organizacional não for o museu da pessoa, digite a organização autora ou deixe-o campo em branco (por padrão ele já vem preenchido).</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>synopsis</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Sinopse da História</label>
          <input-type>textarea</input-type>
          <repeatable>False</repeatable>
          <required>Você precisa inserir um sinopse para sua História ficar completa!</required>
          <hint>Conte para gente um resumo de sua história.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>support</dc-element>
          <dc-qualifier />
          <parent />
          <label>Tipo de Suporte</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required>Você precisa escolher o tipo de arquivo!</required>
          <hint>Escolha o tipo de arquivo que irá conter sua história; podendo ser áudio, texto ou vídeo.</hint>
	<vocabulary closed="true">tipoSuporte</vocabulary>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>date</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Data do Registro</label>
          <input-type>date</input-type>
          <repeatable>false</repeatable>
          <required>Você precisa inserir uma data!</required>
          <hint>Insira a data do registro.</hint>
        </field>

        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>language</dc-element>
          <dc-qualifier>iso</dc-qualifier>
          <parent />
          <label>Idioma</label>
          <input-type value-pairs-name="iso_languages">dropdown</input-type>
          <repeatable>false</repeatable>
          <required>Você precisa escolher um idioma!</required>
          <hint>Selecione o idioma em que sua história se apresenta.</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>subject</dc-element>
          <dc-qualifier />
          <parent />
          <label>Tag</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required>Você precisa inserir pelo uma tag!</required>
          <hint>Insira tags que tenham a ver com sua história para facilitar sua visibilidade.</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>history</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>História</label>
          <input-type>textarea</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Você pode escrever sua história diretamente aqui, ou inserir um arquivo de texto com ela nas próximas páginas.</hint>
        </field>
      </page>
      <page number="2">
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>registration</dc-element>
          <dc-qualifier>code</dc-qualifier>
          <parent />
          <label>Código de Registro</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Insira o Código de Registro</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>project</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Projeto</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Esta história faz parte de um Projeto? Insira-a neste campo.
            *Lembre-se que o projeto precisa estar cadastrado na plataforma.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>team</dc-qualifier>
          <parent>dc_team</parent>
          <label>Integrante da Equipe</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Digite seu nome como participante da equipe!
            *Lembre-se que o participante precisa estar cadastrado na plataforma.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>team</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent/>
          <label>Equipe</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required/>
          <hint>Participa de alguma equipe? Insira-a neste campo.</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>paper</dc-qualifier>
          <parent>dc_team_paper</parent>
          <label>Integrante da Equipe</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Digite seu nome como participante da equipe!
            *Lembre-se que o participante precisa estar cadastrado na plataforma.</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>team</dc-element>
          <dc-qualifier>paper</dc-qualifier>
          <parent></parent>
          <label>Papel na Equipe</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required/>
          <hint>Participa de uma Equipe? Insira aqui seu papel nela.</hint>
          <vocabulary closed="true">papeis</vocabulary>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>support</dc-element>
          <dc-qualifier>present</dc-qualifier>
          <parent />
          <label>Suporte Atual</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required>Você precisa escolher o tipo de arquivo!</required>
          <hint>Escolha o tipo de arquivo usado atualmente na história; podendo ser áudio, texto ou vídeo.</hint>
	  <vocabulary closed="true">tipoSuporte</vocabulary>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>support</dc-element>
          <dc-qualifier>old</dc-qualifier>
          <parent />
          <label>Suporte Antigo</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required></required>
          <hint>Escolha o tipo de arquivo usado anteriormente na história; podendo ser áudio, texto ou vídeo.</hint>
          <vocabulary closed="true">tipoSuporte</vocabulary>
        </field>
         <field>
          <dc-schema>dc</dc-schema>
          <dc-element>duration</dc-element>
          <dc-qualifier />
          <parent />
          <label>Duração</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required></required>
          <hint>Em caso de vídeo ou áudio, Insira aqui a duração da mídia.*Use somente números!</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>chromia</dc-element>
          <dc-qualifier />
          <parent />
          <label>Cromia</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required/>
          <hint>Insira aqui a cromia do item.</hint>
        </field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>record</dc-element>
          <dc-qualifier>city</dc-qualifier>
          <parent />
          <label>Cidade do Registro</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required>Você precisa inserir uma cidade!</required>
          <hint>Insira a cidade do registro.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>record</dc-element>
          <dc-qualifier>state</dc-qualifier>
          <parent />
          <label>Estado do Registro</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required>Você precisa inserir um Estado!</required>
          <hint>Insira a Estado do registro.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>record</dc-element>
          <dc-qualifier>country</dc-qualifier>
          <parent />
          <label>País do Registro</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required>Você precisa inserir um país!</required>
          <hint>Insira o país do registro</hint>
        </field>

        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>interview</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Entrevista Transcrita</label>
          <input-type>textarea</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Caso houver, insira uma entrevista.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>affiliation</dc-qualifier>
          <parent>dc_contributor_museologist</parent>
          <label>Organização</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required/>
          <hint>Participa de alguma organização? Insira-a neste campo. 
            *Lembre-se que a organização precisa estar cadastrada na plataforma.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>museologist</dc-qualifier>
          <parent />
          <label>Responsável por Catalogação</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required>Você precisa pôr um responsável!</required>
          <hint>Insira o responsável por catalogação.
            *Lembre-se que o responsável precisa estar cadastrado na plataforma.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>comments</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Observações</label>
          <input-type>textarea</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Insira a qualquer observação que for necessário.</hint>
        </field>

        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>collection</dc-element>
          <dc-qualifier>location</dc-qualifier>
          <parent />
          <label>Localização no Acervo</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Insira onde este item se encontra no acervo.</hint>
        </field>
      </page>
      <page number="3">
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>affiliation</dc-qualifier>
          <parent>dc_contributor_director</parent>
          <label>Organização</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required/>
          <hint>Participa de alguma organização? Insira-a neste campo.
            *Lembre-se que a organização precisa estar cadastrada na plataforma.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>director</dc-qualifier>
          <parent />
          <label>Realizador</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Insira o realizador do processo.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>production</dc-element>
          <dc-qualifier>context</dc-qualifier>
          <parent />
          <label>Contexto de Produção</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required></required>
          <hint>Insira aqui o contexto de produção.</hint>
        </field>
      </page>
    </form>
    <form name="midia">
      <page number="1">
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>title</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Título</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Digite o título da mídia.</hint>
        </field>
        <field>
	  <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>author</dc-qualifier>
          <parent />
          <label>Pessoa(s) ligada(s) à mídia</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
