          <hint>Digite informações sobre a Cromia da mídia.</hint>
        </field>	
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>credits</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
          <label>Créditos</label>
          <input-type>textarea</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Digite os créditos referêntes a mídia.</hint>
        </field>

        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>subject</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Tag</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required />
          <hint>Digite tags referentes a mídia.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>duration</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
          <label>Duração</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Digite a duração referentes a mídia.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>youtube</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
          <label>Vídeo do Youtube</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Insira o código de incorporação do vídeo aqui! *Para obter o código bastar clicar em cima do vídeo no yotube com o botão direito do mouse e clicar em "copiar código de incorporação".</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>synopsis</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
          <label>Sinopse</label>
          <input-type>textarea</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Digite a sinopse.</hint>
        </field>
      </page>
      <page number="2">
	 <field>
          <dc-schema>dc</dc-schema>
          <dc-element>code</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
          <label>Código do Acervo</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Digite o código do acervo.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>previusrecords</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
