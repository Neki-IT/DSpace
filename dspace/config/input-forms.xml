          <parent />
          <label>Suporte Antigo</label>
          <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required />
          <hint>Escolha o tipo de suporte.</hint>
	  <vocabulary closed="true">tipoSuporte</vocabulary>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>contributor</dc-element>
          <dc-qualifier>museologistmidia</dc-qualifier>
          <parent />
          <label>Responsável pela Catalogação</label>
          <input-type>onebox</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint></hint>
	</field>
	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>observation</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
          <label>Observações</label>
          <input-type>textarea</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Digite as observações.</hint>
        </field>
       </page>
