          <dc-element>resolutionmidia</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Resolução</label>
          <input-type value-pairs-name="resolution">dropdown</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Escolha a resolução da mídia em caso vídeo.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>formatmidia</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Formato</label>
          <input-type value-pairs-name="tipomidia">dropdown</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Escolha o formato da mídia em caso vídeo.</hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>ratiomidia</dc-element>
          <dc-qualifier></dc-qualifier>
          <parent />
          <label>Ratio</label>
          <input-type value-pairs-name="ratio">dropdown</input-type>
          <repeatable>false</repeatable>
          <required />
          <hint>Escolha um item.</hint>
        </field>
      </page>
      <page number="3">
      	<field>
          <dc-schema>dc</dc-schema>
          <dc-element>decupage</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
          <label>Decupagem</label>
          <input-type>onebox</input-type>

          <repeatable>false</repeatable>
          <required />
          <hint></hint>
        </field>
        <field>
          <dc-schema>dc</dc-schema>
          <dc-element>currentsupport</dc-element>
          <dc-qualifier>midia</dc-qualifier>
          <parent />
          <label>Suporte Atual</label>
	  <input-type>onebox</input-type>
          <repeatable>true</repeatable>
          <required />
          <hint>Escolha o tipo de suporte.</hint>
